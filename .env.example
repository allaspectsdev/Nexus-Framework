# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Local model (exo cluster, OpenAI-compatible endpoint)
EXO_ENDPOINT=http://localhost:52415/v1
EXO_MODEL=llama-3.3-70b

# Claude model selection
CLAUDE_MODEL=claude-sonnet-4-6-20250514

# Dashboard
DASHBOARD_PORT=3456

# Routing thresholds
ROUTING_COMPLEXITY_THRESHOLD=0.6

# Context decay (turns before each tier)
CONTEXT_DECAY_FULL_TURNS=2
CONTEXT_DECAY_SUMMARY_TURNS=5

# Agent limits
MAX_CONCURRENT_AGENTS=4

# Observer system (meta-cognitive side-inference)
OBSERVERS_ENABLED=true
OBSERVER_MODEL=local
OBSERVER_SAFETY=true
OBSERVER_MEMORY=true
OBSERVER_COST=true

# Memory system
MEMORY_DIR=.nexus/memory
MEMORY_MAX_ENTRIES=200
MEMORY_MAX_PROMPT_ENTRIES=20
